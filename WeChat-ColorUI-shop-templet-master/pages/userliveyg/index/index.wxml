<view class="cu-custom bg-white" style="height:50px;">
    <view class="cu-bar fixed none-bg  bg-img" style="height:{{CustomBar}}px;padding-top:{{StatusBar}}px;">
        <view class="head-title canui-head-title" style="font-weight: 550;">广天特邀直播</view>
    </view>
</view>

<view class="cu-bar bg-white fixed" style="margin-top:165rpx;">
    <image mode="widthFix" src="{{iconurl}}logo.jpg"></image>
</view>


<!-- 直播间容器 -->
<view class="live-container" style='margin-top: 280rpx;'>

<!-- 直播封面 + 信息 -->
 <view class="live-cover">
  <swiper autoplay="true" circular="true" class="screen-swiper square-dot shadow-warp bg-white" duration="300" indicatorDots="true" interval="5000" >
        <swiper-item wx:for="{{swiperList}}" wx:key="itemid">
            <image  mode="aspectFit" src="{{banner}}{{item.img}}" style="height: 450rpx; width: 1080rpx;"></image>
        </swiper-item>
    </swiper>

  <view class="live-info">
    <text class="live-status">{{isLiving ? '直播中' : '预告'}}</text>
    <text class="live-title" style='margin-top: 2rpx;'>{{liveTitle}}</text>
  </view>
</view> 
</view>

    <view class="cu-form-group" style="margin-top: -750rpx;">
        <view class="title icon-title text-orange">输入会员卡号：</view>
        <input bindinput="getvipcode" class="radius dp" name="vipcode" placeholder="请输入会员卡号精准查询" value="{{vipcode}}"></input>
    </view>
    <view style="display: flex;width: 100%;margin-top: 10px;padding-bottom: 10px;">
        <view bindtap="listvipcode" style="margin-left:8rem;width:20%;width:30%;">
            <button class="cu-btn bg-gradual-green shadow-blur round">查询</button>
        </view>
    </view>
    <view class="cu-form-group" style="padding-top: 20px;">
        <view class="title icon-title text-orange up">会员姓名：</view>
        <text class="text-grey">{{vipname}}</text>
    </view>
    <view class="cu-form-group">
        <view class="title icon-title text-orange up">会员等级：</view>
        <text class="text-grey">{{grade}}</text>
    </view>
    <view class="cu-form-group">
        <view class="title icon-title text-orange up">会员店铺：</view>
        <text class="text-grey">{{store}}</text>
    </view>
    <view class="cu-form-group">
        <view class="title icon-title text-orange up">跟进员工：</view>
        <text class="text-grey">{{xf_name}}</text>
    </view>


    <view  style="margin:0px 10px 10px 5px;width:90%;padding-bottom: 3rem;padding-top: 2rem;">
        <button class="cu-btn round  bg-gradual-green" openType="share" style="margin:5px 5px 5px 5px;height:2.5rem;border-radius: 0.8rem;color:white;background-color: #03a9f4;border:1px solid ;width:100%;font-size: 16px;"> 分享直播给此客户</button>
    </view>



