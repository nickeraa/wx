
.cu-custom .cu-bar{
	background-image: 
	linear-gradient(45deg, #6abae9, #4668d8);
	padding-right: inherit;

}
page{
padding-bottom: 20rpx;
padding-top:170rpx;
width:100%;
background-color: grey;
overflow: hidden;
}
.head-title{
margin:0 auto;
}
.text-center{
	text-align: center;margin-top:
	80rpx;

}
.regist
{
  width:22.5rem;
  height: 30rem;
  background-color: white;
  margin-left: 1rem;
  margin-top:8rem;
  border-radius: 30rpx;
  overflow: hidden; /* 强制切圆角 */

}

/* 每个单选选项 */
.radio-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
  font-size: 30rpx;
  color: #333;
}

/* 单选按钮本身 */
radio {
  margin-right: 10rpx;
  transform: scale(0.9); /* 调整大小 */
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.picker-box {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
}

.upload-box {
  width: 220rpx;
  height: 220rpx;
  border: 2rpx dashed #cccccc;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.upload-box image {
  width: 100%;
  height: 100%;
}
.add-text {
  color: #999;
  font-size: 28rpx;
}

