<!--pages/regist/index.wxml-->
<!-- 导航栏 -->
<view class="cu-custom">
	<view class="cu-bar fixed text-white" style="height:{{CustomBar}}px;padding-top:{{StatusBar}}px;">
	    <navigator class='action' open-type="navigateBack" delta="1" hover-class="none">
      <text class='cuIcon-back'></text> 返回
    </navigator>	
		
		<view class="head-title">
			身份核验</view>
	</view>
</view>

<view class='regist'>
<view class="cu-form-group"
style='padding-top: 2rem;
margin-left: 2rem;'>
		<view class="title cuIcon-title text-orange" 
    >姓名：</view>
		<input bindinput='getusername' placeholder="请输入姓名"></input>
	</view>

  <view class="cu-form-group"
style='padding-top: 0.8rem;
margin-left: 2rem;'>
		<view class="title cuIcon-title text-orange" 
    >身份证号码：</view>
		<input bindinput='getcode' placeholder="请输入完整的身份证号码"></input>
	</view>

  <view class="cu-form-group"
style='padding-top: 0.8rem;
margin-left: 2rem;'>
<view class="title cuIcon-title text-orange" 
    >本人照片：</view>
  <view class="upload-box" bindtap="chooseSingleImg" style='margin-right:3rem;'>
  <image wx:if="{{imgUrl}}" src="{{imgUrl}}" mode="aspectFill"></image>
  <view wx:else class="add-text">
  <text style='font-size:50rpx;'>+</text>
  <text> 点击上传图片</text></view>
</view>
</view>

  <view class="padding-sm" 
  bindtap='apply'>
    <button class="
    bg-gradual-blue round
      text-center shadow-blur">
      <text class="text-lg">确认</text>

    </button>
  </view>



</view>

